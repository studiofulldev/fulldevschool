# =============================================================================
# .env.example — Variáveis de ambiente para desenvolvimento local
# =============================================================================
# Copie este arquivo para .env e preencha os valores:
#   cp .env.example .env
#
# O arquivo .env é lido automaticamente pelo Docker Compose.
# NUNCA commite o .env — ele está no .gitignore.
#
# Após preencher, reinicie apenas o serviço auth para aplicar:
#   docker compose restart auth
# =============================================================================

# -----------------------------------------------------------------------------
# Google OAuth
# Obtenha em: https://console.cloud.google.com → APIs & Services → Credentials
#   1. Crie um projeto (ou use um existente)
#   2. "Create Credentials" → "OAuth 2.0 Client ID" → tipo "Web application"
#   3. Authorized redirect URIs: http://localhost:8000/auth/v1/callback
# Mude GOOGLE_ENABLED para "true" após preencher CLIENT_ID e CLIENT_SECRET.
# -----------------------------------------------------------------------------
GOOGLE_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# LinkedIn OAuth (opcional — só necessário se habilitar login com LinkedIn)
# Obtenha em: https://www.linkedin.com/developers/apps
#   1. Crie um app e habilite "Sign In with LinkedIn using OpenID Connect"
#   2. Authorized redirect URLs: http://localhost:8000/auth/v1/callback
# Mude LINKEDIN_ENABLED para "true" após preencher CLIENT_ID e CLIENT_SECRET.
# -----------------------------------------------------------------------------
LINKEDIN_ENABLED=false
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
