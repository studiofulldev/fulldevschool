# =============================================================================
# .env.example — Variáveis de ambiente para desenvolvimento local
# =============================================================================
# Copie este arquivo para .env e preencha os valores:
#   cp .env.example .env
#
# O arquivo .env é lido automaticamente pelo Docker Compose.
# NUNCA commite o .env — ele está no .gitignore.
#
# Após preencher, reinicie apenas o serviço auth para aplicar:
#   docker compose restart auth
# =============================================================================

# -----------------------------------------------------------------------------
# Google OAuth
# Obtenha em: https://console.cloud.google.com → APIs & Services → Credentials
#   1. Crie um projeto (ou use um existente)
#   2. "Create Credentials" → "OAuth 2.0 Client ID" → tipo "Web application"
#   3. Authorized redirect URIs: http://localhost:8000/auth/v1/callback
# Mude GOOGLE_ENABLED para "true" após preencher CLIENT_ID e CLIENT_SECRET.
# -----------------------------------------------------------------------------
GOOGLE_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# LinkedIn OAuth (login + vinculação de identidade)
# Obtenha em: https://www.linkedin.com/developers/apps
#   1. Crie um app e habilite "Sign In with LinkedIn using OpenID Connect"
#   2. Authorized redirect URLs: http://localhost:8000/auth/v1/callback
# Mude LINKEDIN_ENABLED para "true" após preencher CLIENT_ID e CLIENT_SECRET.
# -----------------------------------------------------------------------------
LINKEDIN_ENABLED=false
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# GitHub OAuth (vinculação de identidade — não usado para login)
# Obtenha em: https://github.com/settings/developers → OAuth Apps → New OAuth App
#   - Application name: Fulldev School (local)
#   - Homepage URL: http://localhost:4200
#   - Authorization callback URL: http://localhost:8000/auth/v1/callback
# Mude GITHUB_ENABLED para "true" após preencher CLIENT_ID e CLIENT_SECRET.
# -----------------------------------------------------------------------------
GITHUB_ENABLED=false
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# GitHub Personal Access Token — Edge Function sync-pr-data
# Usado para buscar dados de PRs no GitHub sem limite de 60 req/hora.
# Obtenha em: https://github.com/settings/tokens → "Fine-grained tokens"
#   - Resource owner: sua conta pessoal
#   - Repository access: "Public Repositories (read-only)"
#   - Permissions: nenhuma extra necessária
# Após preencher, reinicie o serviço functions:
#   docker compose up -d functions
# -----------------------------------------------------------------------------
GITHUB_PAT=
